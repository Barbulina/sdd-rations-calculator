#!/bin/sh
# Pre-push hook: run format check, lint, and tests before pushing.
# Installed automatically via `npm install` (prepare script sets core.hooksPath).

echo "🔍 Running format check..."
npm run format:check
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ Format check failed. Push aborted."
  echo "   Run 'npm run format' to fix formatting issues."
  exit 1
fi

echo "🔍 Running linter..."
npm run lint:check
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ Lint check failed. Push aborted."
  exit 1
fi

echo "🧪 Running tests..."
npm test -- --run --exclude="**/design-tokens/**"
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ Tests failed. Push aborted."
  echo "   Fix the failing tests and try again."
  echo "   To skip this check (not recommended): git push --no-verify"
  exit 1
fi

echo "✅ All checks passed. Proceeding with push."
exit 0
